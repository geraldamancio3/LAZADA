@page
@model Microsoft.AspNetCore.Mvc.RazorPages.PageModel
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lazada Philippines | Best Deals & Free Shipping</title>
  <link rel="stylesheet" href="~/styles.css" />
</head>
<body>
  <div class="top-strip">
    <div class="container strip-inner">
      <a href="#">SAVE MORE ON APP</a>
      <a href="#">SELL ON LAZADA</a>
      <a href="#">CUSTOMER CARE</a>
      <a href="#">TRACK MY ORDER</a>
      <a href="#">LOGIN</a>
      <a href="#">SIGN UP</a>
    </div>
  </div>

  <header class="main-header">
    <div class="container header-inner">
      <div class="logo">Lazada</div>
      <div class="search-bar">
        <input type="text" placeholder="Search in Lazada" />
        <button type="button">Search</button>
      </div>
      <div class="header-links">
        <a href="#">Lazada Loans</a>
        <a href="#">Wallet</a>
        <a href="#">Help Center</a>
      </div>
    </div>
  </header>

  <main class="container">
    <section class="hero">
      <div class="hero-banner">
        <span class="pill">Flash Sale</span>
        <h1>Add to Cart, Add to Life</h1>
        <p>Shop from trusted brands, discover exclusive vouchers, and enjoy fast shipping nationwide.</p>
      </div>
      <aside class="hero-app">
        <h2>TRY OUR APP</h2>
        <p class="muted">4.8 Rated</p>
        <ul>
          <li>Free Shipping</li>
          <li>Exclusive Vouchers</li>
          <li>Better deals daily</li>
        </ul>
        <div class="qr-box">QR CODE</div>
      </aside>
    </section>

    <section class="card">
      <div class="section-head">
        <h2>Flash Sale</h2>
        <p>On Sale Now</p>
      </div>
      <div class="product-grid">
        <article class="product-card">
          <div class="thumb">Product</div>
          <h3>OMNI Universal Socket Adapter 10A 250V</h3>
          <p class="price">P59.75</p>
        </article>
        <article class="product-card">
          <div class="thumb">Product</div>
          <h3>PRO COMBAT Running Shorts Quick Dry Training</h3>
          <p class="price">P155.15</p>
        </article>
        <article class="product-card">
          <div class="thumb">Product</div>
          <h3>BAVIN 20000mAh Powerbank Quick Charge</h3>
          <p class="price">P375.00</p>
        </article>
        <article class="product-card">
          <div class="thumb">Product</div>
          <h3>UGREEN USB Type C Fast Charger Data Cord</h3>
          <p class="price">P84.63</p>
        </article>
        <article class="product-card">
          <div class="thumb">Product</div>
          <h3>Birch Tree Fortified Powdered Milk 2kg</h3>
          <p class="price">P500.22</p>
        </article>
      </div>
    </section>

    <section class="card">
      <div class="section-head">
        <h2>Categories</h2>
      </div>
      <div class="categories">
        <span>Mobiles</span>
        <span>T-Shirts & Tanks</span>
        <span>Baby Disposable Diapers</span>
        <span>Power Banks</span>
        <span>Phone Cables</span>
        <span>Women's Dresses</span>
        <span>In-Ear Headphones</span>
        <span>Kitchen Organizers</span>
        <span>Tablets</span>
        <span>Dried Fruit</span>
      </div>
    </section>

    <section class="card">
      <h2>The Top Online Shopping Experience with Lazada Philippines</h2>
      <p>
        As the top online shopping platform in the Philippines, Lazada continues to support a growing
        e-commerce community by helping brands and sellers expand while giving customers easy access to
        quality products, responsive service, and convenient payment options.
      </p>
      <p>
        From free shipping vouchers and major campaigns to app-first experiences and trusted logistics,
        Lazada keeps improving the way Filipinos shop online.
      </p>
    </section>

    <section class="card">
      <h2>LAZADA - ADD TO CART, ADD TO LIFE</h2>
      <p>
        Lazada's services continue to grow through better customer communication, secure payments, authentic
        products, and convenient returns. Buyers can chat with sellers, use multiple payment options, and
        enjoy campaign discounts all year long.
      </p>
      <p>
        Popular shopping events include Birthday Sale, 11.11, and 12.12, offering strong deals across
        electronics, fashion, home, health, and more.
      </p>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <h3>Customer Care</h3>
        <a href="#">Help Center</a>
        <a href="#">How to Buy</a>
        <a href="#">Shipping & Delivery</a>
        <a href="#">How to Return</a>
      </div>
      <div>
        <h3>Lazada</h3>
        <a href="#">About Lazada</a>
        <a href="#">Careers</a>
        <a href="#">Terms & Conditions</a>
        <a href="#">Privacy Policy</a>
      </div>
      <div>
        <h3>Payment Methods</h3>
        <p>Visa, Mastercard, JCB, GCash, Maya, LazWallet</p>
      </div>
      <div>
        <h3>Delivery Services</h3>
        <p>Lazada Logistics, J&T, Flash Express, Ximex</p>
      </div>
    </div>
    <p class="copyright">© Lazada 2026</p>
  </footer>
</body>
</html>
